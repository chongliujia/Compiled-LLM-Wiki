{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compiled-wiki.local/schemas/conflict.json",
  "title": "Conflict",
  "type": "object",
  "required": ["id", "claim_ids", "summary", "status"],
  "properties": {
    "id": { "type": "string" },
    "claim_ids": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string" }
    },
    "summary": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["unresolved", "superseded", "withdrawn"]
    },
    "wiki_entity_id": {
      "type": ["string", "null"],
      "description": "Entity page where this should be rendered"
    }
  },
  "additionalProperties": false
}
